# StrikeCore — example env file. Copy to .env and fill in real values.
# .env is chmod 600 and git-ignored. NEVER commit real values.

# ── LLM providers ──
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
OPENROUTER_API_KEY=
VLLM_API_KEY=
CUSTOM_API_KEY=local

# ── Container identity (decision I3) ──
# Set to your host operator UID/GID so bind-mounted state stays operator-owned:
#   APP_UID=$(id -u)  APP_GID=$(id -g)
APP_UID=1000
APP_GID=1000

# ── Postgres ──
# Host port is 5433 (5432 is taken by a sister project); inside compose the
# backend/toolbox reach it as host `postgres` on 5432 (set via compose env).
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=strikecore
POSTGRES_PASSWORD=GENERATE_STRONG_RANDOM
POSTGRES_DB=strikecore

# ── Redis (for future job queue) ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=GENERATE_STRONG_RANDOM

# ── Tor ControlPort ──
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=GENERATE_STRONG_RANDOM

# ── Web auth ──
JWT_SECRET=GENERATE_STRONG_RANDOM
AUTH_SECRET=GENERATE_STRONG_RANDOM

# ── Telegram / WhatsApp / Twilio ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── External OSINT APIs ──
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
IPINFO_TOKEN=
HIBP_API_KEY=
DEHASHED_API_KEY=
INTELX_API_KEY=
HUNTERIO_API_KEY=
EMAILREP_API_KEY=
NUMVERIFY_API_KEY=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
SECURITYTRAILS_API_KEY=
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=
